{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retireaway.com/schemas/user-profile.schema.json",
  "title": "UserProfile",
  "description": "The profile of a user, containing their saved items and preferences.",
  "type": "object",
  "properties": {
    "saved": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "type": { "const": "Destination" },
              "timestamp": { "type": "string", "format": "date-time" },
              "item": { "$ref": "destination.schema.json" }
            },
            "required": ["id", "type", "timestamp", "item"]
          },
          {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "type": { "const": "Resource" },
              "timestamp": { "type": "string", "format": "date-time" },
              "item": { "$ref": "resource.schema.json" }
            },
            "required": ["id", "type", "timestamp", "item"]
          },
          {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "type": { "const": "Provider" },
              "timestamp": { "type": "string", "format": "date-time" },
              "item": { "$ref": "provider.schema.json" }
            },
            "required": ["id", "type", "timestamp", "item"]
          },
          {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "type": { "const": "Comparison" },
              "timestamp": { "type": "string", "format": "date-time" },
              "item": {
                "type": "array",
                "items": { "$ref": "destination.schema.json" }
              }
            },
            "required": ["id", "type", "timestamp", "item"]
          }
        ]
      }
    }
  },
  "required": ["saved"],
  "additionalProperties": false
}
