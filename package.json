{
  "name": "retireaway-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://retireaway.jeremiaholatunde.com",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:destinations": "pnpx node --experimental-strip-types scripts/generate.ts",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages --dist dist --cname retireaway.com"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/sora": "^5.2.8",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "fuse.js": "^7.4.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "temporal-polyfill": "^0.3.2",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "csv": "^6.5.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "node": "^24.16.0",
    "prettier": "3.8.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.5",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "10.32.1",
      "onFail": "error"
    }
  }
}
